{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cargo +nightly fmt --quiet 2>/dev/null; true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$CLAUDE_TOOL_INPUT\" | grep -q 'Cargo.lock' && echo 'BLOCK: Do not edit Cargo.lock directly — use cargo update instead' && exit 1; exit 0"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(cargo:*)",
      "Bash(rustup:*)",
      "Bash(mise:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs",
      "mcp__claude_ai_Context7__resolve-library-id",
      "mcp__claude_ai_Context7__query-docs",
      "mcp__basic-memory__search_notes",
      "mcp__basic-memory__write_note",
      "mcp__basic-memory__read_note",
      "mcp__basic-memory__list_directory",
      "mcp__plugin_github_github__issue_read",
      "mcp__plugin_github_github__pull_request_read",
      "mcp__plugin_github_github__list_commits"
    ]
  }
}
