{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":preserveSemverRanges"
  ],
  "enabledManagers": [
    "cargo",
    "woodpecker"
  ],
  "packageRules": [
    {
      "matchManagers": ["cargo"],
      "addLabels": ["rust"]
    },
    {
      "matchManagers": ["woodpecker"],
      "addLabels": ["docker"]
    },
    {
      "description": "Auto-merge patch and minor Cargo updates — CI-verified",
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true
    }
  ]
}
